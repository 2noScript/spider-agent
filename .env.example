# =========================
# FASTAPI
# =========================
RELOAD_ON_FILE_CHANGE=true
FASTAPI_PORT=80
FASTAPI_DEBUG=false

# =========================
# AI KEYS
# =========================
GOOGLE_API_KEY=your_google_api_key
OPENAI_API_KEY=your_openai_api_key

# =========================
# ENGINE SETTINGS
# =========================
CAMOFOX_COOKIES_DIR=/path/to/cookies

HANDLER_TIMEOUT_S=30
SESSION_TIMEOUT_S=600
TAB_INACTIVITY_S=300

MAX_CONCURRENT_PER_USER=3
MAX_SESSIONS=50
MAX_TABS_PER_SESSION=10
MAX_TABS_GLOBAL=10

NAVIGATE_TIMEOUT_S=25
BUILDREFS_TIMEOUT_S=12
BROWSER_IDLE_TIMEOUT_S=300